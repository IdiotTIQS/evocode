# 复制为 .env 并填入真实值后运行 docker compose up。
# JWT 签名密钥：必须 >=32 字节。生成示例：
#   openssl rand -hex 32
# 下面是占位值（故意过短）：直接照搬会让控制平面在 JWT 初始化时报错退出，
# 提醒你换成真实随机密钥——而非用一个提交在源码里的“看似有效”的密钥静默启动。
EVOCODE_JWT_SECRET=REPLACE_ME

# ── 可选：接入真实 LLM（plan + 代码生成）────────────────────────────────────
# 留空则用确定性 stub 规划 + 模板生成（无需任何凭证、可离线跑）。
# 填写后 plan 与 generate 阶段都走真实 LLM。DeepSeek 为 OpenAI 兼容接口：
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-v4-pro      （推理模型；运行时已留足 token 额度）
#   OPENAI_API_KEY=<你的 DeepSeek key> （切勿提交真实 key）
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

